# =============================================================================
# .gitignore — Cyber Attack Detection System
# =============================================================================

# ---- Python ----
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt

# ---- NOTE: .pkl model files ARE included (attack_model.pkl ~24 MB, under GitHub's 100 MB limit) ----
# To regenerate locally: python train_model.py

# ---- Dataset (25 MB+ raw data) ----
KDDTrain+.txt
KDDTest+.txt
dataset/

# ---- Database (runtime data, not source code) ----
*.db
*.sqlite
*.sqlite3

# ---- Secrets / Environment ----
.env
.env.*
*.key

# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini

# ---- IDE ----
.vscode/
.idea/
*.code-workspace
